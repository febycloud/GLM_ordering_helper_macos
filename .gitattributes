# 强制 shell 脚本为 LF 行尾，避免执行时 /bin/bash^M 错误
*.sh           text eol=lf
*.command      text eol=lf

# 油猴脚本/JS/Python/文档用 LF
*.js           text eol=lf
*.py           text eol=lf
*.md           text eol=lf
*.html         text eol=lf
*.json         text eol=lf
*.txt          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf

# 二进制文件
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.zip          binary
*.pt           binary
*.safetensors  binary
*.onnx         binary
*.ico          binary
